<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>基金查看系统</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Microsoft YaHei', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .header p {
            opacity: 0.9;
            font-size: 0.95em;
        }

        .add-fund-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        }

        .add-fund-form {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .add-fund-form input {
            flex: 1;
            min-width: 200px;
            padding: 14px 18px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        .add-fund-form input:focus {
            outline: none;
            border-color: #667eea;
        }

        .btn {
            padding: 14px 28px;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }

        .btn-success {
            background: #28a745;
        }

        .btn-success:hover {
            background: #218838;
        }

        .btn-danger {
            background: #dc3545;
        }

        .btn-danger:hover {
            background: #c82333;
        }

        .funds-grid {
            display: grid;
            gap: 16px;
        }

        .fund-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            display: grid;
            grid-template-columns: auto 1fr auto auto;
            align-items: center;
            gap: 16px;
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: grab;
            user-select: none;
        }

        .fund-card:hover {
            transform: translateY(-3px);
        }

        .fund-card.loading {
            opacity: 0.7;
        }

        .fund-card.dragging {
            opacity: 0.5;
            transform: scale(1.02);
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            cursor: grabbing;
        }

        .fund-card.drag-over {
            border: 2px dashed #667eea;
            transform: translateY(5px);
        }

        .drag-handle {
            width: 24px;
            height: 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 3px;
            cursor: grab;
            opacity: 0.3;
            transition: opacity 0.2s;
        }

        .fund-card:hover .drag-handle {
            opacity: 0.6;
        }

        .drag-handle span {
            width: 16px;
            height: 2px;
            background: #666;
            border-radius: 1px;
        }

        .fund-info h3 {
            font-size: 1.1em;
            color: #333;
            margin-bottom: 6px;
        }

        .fund-info .code {
            color: #888;
            font-size: 0.9em;
        }

        .fund-data {
            text-align: right;
        }

        .fund-data .nav {
            font-size: 1.4em;
            font-weight: bold;
            color: #333;
        }

        .fund-data .change {
            font-size: 1.2em;
            font-weight: bold;
            padding: 4px 12px;
            border-radius: 6px;
            display: inline-block;
            margin-top: 4px;
        }

        .fund-data .change.up {
            color: #d32f2f;
            background: #ffebee;
        }

        .fund-data .change.down {
            color: #2e7d32;
            background: #e8f5e9;
        }

        .fund-data .change.neutral {
            color: #666;
            background: #f5f5f5;
        }

        .fund-data .time {
            font-size: 0.8em;
            color: #999;
            margin-top: 6px;
        }

        .delete-btn {
            background: #ff5252;
            color: white;
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 18px;
            transition: background 0.3s;
        }

        .delete-btn:hover {
            background: #d32f2f;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 16px;
            color: #888;
        }

        .empty-state svg {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .loading-spinner {
            text-align: center;
            padding: 40px;
            color: white;
            font-size: 1.2em;
        }

        .source-info {
            text-align: center;
            color: rgba(255,255,255,0.7);
            font-size: 0.85em;
            margin-top: 30px;
        }

        .toast {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            padding: 12px 24px;
            background: #333;
            color: white;
            border-radius: 8px;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 1000;
        }

        .toast.show {
            opacity: 1;
        }

        .toast.error {
            background: #d32f2f;
        }

        .toast.success {
            background: #2e7d32;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 20px;
            color: white;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-size: 1.5em;
            font-weight: bold;
        }

        .stat-label {
            font-size: 0.9em;
            opacity: 0.8;
        }

        .export-import {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }

        .export-import button {
            padding: 10px 16px;
            font-size: 14px;
        }

        @media (max-width: 600px) {
            .fund-card {
                grid-template-columns: auto 1fr;
                text-align: center;
            }

            .fund-card .fund-info,
            .fund-card .fund-data {
                grid-column: 2;
            }

            .fund-card .fund-data {
                text-align: center;
            }

            .fund-card .delete-btn {
                grid-column: 2;
                justify-self: center;
            }

            .add-fund-form {
                flex-direction: column;
            }

            .stats {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>基金查看系统</h1>
            <p>数据来源：天天基金网 (fund.eastmoney.com)</p>
        </div>

        <div class="stats" id="stats" style="display: none;">
            <div class="stat-item">
                <div class="stat-value" id="totalFunds">0</div>
                <div class="stat-label">持仓基金</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="upCount">0</div>
                <div class="stat-label">上涨</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="downCount">0</div>
                <div class="stat-label">下跌</div>
            </div>
        </div>

        <div class="add-fund-card">
            <form class="add-fund-form" onsubmit="addFund(event)">
                <input type="text" id="fundCode" placeholder="输入6位基金代码，如：000001" maxlength="6">
                <button type="submit" class="btn btn-primary">添加基金</button>
                <button type="button" class="btn btn-success" onclick="refreshAllFunds()">刷新全部</button>
            </form>
            <div class="export-import">
                <button class="btn btn-primary" onclick="exportData()">导出数据</button>
                <button class="btn btn-success" onclick="document.getElementById('importFile').click()">导入数据</button>
                <input type="file" id="importFile" accept=".json" style="display:none" onchange="importData(event)">
                <button class="btn btn-danger" onclick="clearAllData()">清空数据</button>
            </div>
        </div>

        <div id="fundsContainer" class="funds-grid">
            <div class="loading-spinner">加载中...</div>
        </div>

        <div class="source-info">
            数据由天天基金网提供，仅供参考 | 估值数据每交易日9:00-15:00更新<br>
            数据保存在浏览器本地 (localStorage)，清除浏览器数据会丢失
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <script>
        // 存储键名
        const STORAGE_KEY = 'fund_tracker_data';

        // 页面加载时初始化
        document.addEventListener('DOMContentLoaded', init);

        function init() {
            loadAndDisplayFunds();
        }

        // 从本地存储加载基金列表
        function loadFundCodes() {
            try {
                const data = localStorage.getItem(STORAGE_KEY);
                return data ? JSON.parse(data) : [];
            } catch {
                return [];
            }
        }

        // 保存基金列表到本地存储
        function saveFundCodes(codes) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(codes));
        }

        // 从天天基金网获取基金数据
        async function fetchFundData(fundCode) {
            return new Promise((resolve) => {
                const callbackName = `jsonpgz_${fundCode}_${Date.now()}`;
                const script = document.createElement('script');

                // 设置超时
                const timeout = setTimeout(() => {
                    cleanup();
                    resolve({
                        code: fundCode,
                        success: false,
                        error: '请求超时'
                    });
                }, 10000);

                function cleanup() {
                    clearTimeout(timeout);
                    delete window[callbackName];
                    if (script.parentNode) {
                        script.parentNode.removeChild(script);
                    }
                }

                // 天天基金会调用 jsonpgz 函数
                window.jsonpgz = function(data) {
                    cleanup();
                    resolve({
                        code: data.fundcode || fundCode,
                        name: data.name || '未知基金',
                        nav: data.dwjz || '--',
                        estimateNav: data.gsz || '--',
                        estimateChange: data.gszzl || '--',
                        navDate: data.jzrq || '--',
                        estimateTime: data.gztime || '--',
                        success: true
                    });
                };

                script.onerror = function() {
                    cleanup();
                    resolve({
                        code: fundCode,
                        success: false,
                        error: '加载失败'
                    });
                };

                // 天天基金实时估值接口
                script.src = `https://fundgz.1234567.com.cn/js/${fundCode}.js?rt=${Date.now()}`;
                document.head.appendChild(script);
            });
        }

        // 加载并显示所有基金
        async function loadAndDisplayFunds() {
            const container = document.getElementById('fundsContainer');
            const codes = loadFundCodes();

            if (codes.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p>还没有添加任何基金</p>
                        <p style="margin-top: 10px;">在上方输入基金代码开始追踪</p>
                    </div>
                `;
                document.getElementById('stats').style.display = 'none';
                return;
            }

            container.innerHTML = '<div class="loading-spinner">正在获取最新数据...</div>';

            // 并行获取所有基金数据
            const fundsData = await Promise.all(codes.map(code => fetchFundData(code)));

            // 统计涨跌
            let upCount = 0, downCount = 0;
            fundsData.forEach(fund => {
                if (fund.success) {
                    const change = parseFloat(fund.estimateChange) || 0;
                    if (change > 0) upCount++;
                    else if (change < 0) downCount++;
                }
            });

            // 更新统计
            document.getElementById('stats').style.display = 'flex';
            document.getElementById('totalFunds').textContent = codes.length;
            document.getElementById('upCount').textContent = upCount;
            document.getElementById('downCount').textContent = downCount;

            // 渲染基金卡片
            container.innerHTML = fundsData.map((fund, index) => createFundCard(fund, index)).join('');

            // 添加拖拽事件
            setupDragAndDrop();
        }

        // 创建基金卡片HTML
        function createFundCard(fund, index) {
            if (!fund.success) {
                return `
                    <div class="fund-card" draggable="true" data-index="${index}" data-code="${fund.code}">
                        <div class="drag-handle"><span></span><span></span><span></span></div>
                        <div class="fund-info">
                            <h3>获取失败: ${fund.error || '未知错误'}</h3>
                            <span class="code">${fund.code}</span>
                        </div>
                        <div class="fund-data">
                            <span class="change neutral">--</span>
                        </div>
                        <button class="delete-btn" onclick="deleteFund('${fund.code}')">×</button>
                    </div>
                `;
            }

            const change = parseFloat(fund.estimateChange) || 0;
            const changeClass = change > 0 ? 'up' : (change < 0 ? 'down' : 'neutral');
            const changeText = change > 0 ? `+${fund.estimateChange}%` : `${fund.estimateChange}%`;

            return `
                <div class="fund-card" draggable="true" data-index="${index}" data-code="${fund.code}">
                    <div class="drag-handle"><span></span><span></span><span></span></div>
                    <div class="fund-info">
                        <h3>${fund.name}</h3>
                        <span class="code">${fund.code}</span>
                    </div>
                    <div class="fund-data">
                        <div class="nav">估值: ${fund.estimateNav}</div>
                        <div class="change ${changeClass}">${changeText}</div>
                        <div class="time">净值: ${fund.nav} (${fund.navDate})</div>
                        <div class="time">估算时间: ${fund.estimateTime}</div>
                    </div>
                    <button class="delete-btn" onclick="deleteFund('${fund.code}')">×</button>
                </div>
            `;
        }

        // 添加基金
        async function addFund(event) {
            event.preventDefault();
            const input = document.getElementById('fundCode');
            const code = input.value.trim();

            if (!/^\d{6}$/.test(code)) {
                showToast('请输入6位数字基金代码', 'error');
                return;
            }

            const codes = loadFundCodes();
            if (codes.includes(code)) {
                showToast('该基金已存在', 'error');
                return;
            }

            showToast('正在验证基金代码...', '');

            // 验证基金是否存在
            const fundData = await fetchFundData(code);
            if (!fundData.success) {
                showToast('基金代码不存在或无法获取数据', 'error');
                return;
            }

            codes.push(code);
            saveFundCodes(codes);
            input.value = '';
            showToast(`成功添加: ${fundData.name}`, 'success');
            loadAndDisplayFunds();
        }

        // 删除基金
        function deleteFund(code) {
            if (!confirm('确定要删除这个基金吗？')) return;

            const codes = loadFundCodes();
            const index = codes.indexOf(code);
            if (index > -1) {
                codes.splice(index, 1);
                saveFundCodes(codes);
                showToast('删除成功', 'success');
                loadAndDisplayFunds();
            }
        }

        // 刷新所有基金
        function refreshAllFunds() {
            showToast('正在刷新数据...', '');
            loadAndDisplayFunds();
        }

        // 导出数据
        function exportData() {
            const codes = loadFundCodes();
            const data = {
                funds: codes,
                exportTime: new Date().toISOString(),
                version: '1.0'
            };

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `funds_backup_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('数据已导出', 'success');
        }

        // 导入数据
        function importData(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = JSON.parse(e.target.result);
                    if (data.funds && Array.isArray(data.funds)) {
                        const codes = loadFundCodes();
                        let addedCount = 0;
                        data.funds.forEach(code => {
                            if (/^\d{6}$/.test(code) && !codes.includes(code)) {
                                codes.push(code);
                                addedCount++;
                            }
                        });
                        saveFundCodes(codes);
                        showToast(`成功导入 ${addedCount} 个基金`, 'success');
                        loadAndDisplayFunds();
                    } else {
                        showToast('无效的数据格式', 'error');
                    }
                } catch {
                    showToast('解析文件失败', 'error');
                }
            };
            reader.readAsText(file);
            event.target.value = '';
        }

        // 清空所有数据
        function clearAllData() {
            if (!confirm('确定要清空所有基金数据吗？此操作不可恢复！')) return;
            localStorage.removeItem(STORAGE_KEY);
            showToast('数据已清空', 'success');
            loadAndDisplayFunds();
        }

        // 拖拽相关变量
        let draggedCard = null;
        let draggedIndex = null;

        // 设置拖拽事件
        function setupDragAndDrop() {
            const cards = document.querySelectorAll('.fund-card');
            const container = document.getElementById('fundsContainer');

            cards.forEach(card => {
                card.addEventListener('dragstart', handleDragStart);
                card.addEventListener('dragend', handleDragEnd);
                card.addEventListener('dragover', handleDragOver);
                card.addEventListener('drop', handleDrop);
                card.addEventListener('dragenter', handleDragEnter);
                card.addEventListener('dragleave', handleDragLeave);
            });
        }

        function handleDragStart(e) {
            draggedCard = this;
            draggedIndex = parseInt(this.dataset.index);
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', draggedIndex);
        }

        function handleDragEnd(e) {
            this.classList.remove('dragging');
            draggedCard = null;
            draggedIndex = null;

            // 清除所有 drag-over 样式
            document.querySelectorAll('.fund-card').forEach(card => {
                card.classList.remove('drag-over');
            });
        }

        function handleDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
        }

        function handleDragEnter(e) {
            e.preventDefault();
            if (this !== draggedCard) {
                this.classList.add('drag-over');
            }
        }

        function handleDragLeave(e) {
            this.classList.remove('drag-over');
        }

        function handleDrop(e) {
            e.preventDefault();
            this.classList.remove('drag-over');

            if (this === draggedCard) return;

            const dropIndex = parseInt(this.dataset.index);
            if (draggedIndex === null || dropIndex === null) return;

            // 获取当前基金代码列表
            const codes = loadFundCodes();

            // 交换位置
            const [movedCode] = codes.splice(draggedIndex, 1);
            codes.splice(dropIndex, 0, movedCode);

            // 保存新顺序
            saveFundCodes(codes);

            // 重新渲染
            loadAndDisplayFunds();

            showToast('排序已更新', 'success');
        }

        // 显示提示
        function showToast(message, type = '') {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = `toast show ${type}`;

            setTimeout(() => {
                toast.className = 'toast';
            }, 3000);
        }

        // 自动刷新（每分钟）
        setInterval(() => {
            if (loadFundCodes().length > 0) {
                loadAndDisplayFunds();
            }
        }, 60000);
    </script>
</body>
</html>
